---
import { ArrowUpRight, Download, Mail } from 'lucide-react'
import { ThemeToggle } from './ThemeToggle'
import type { Lang, PageContent } from '@/i18n/content'

interface Props {
  lang: Lang
  page: PageContent
}

const { lang, page } = Astro.props
const cvPath = '/cv/Piotr_Ponikiewski_cv.pdf'
const profilePath = '/images/profile.webp'
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={page.meta.description} />
    <title>{page.meta.title}</title>
    <script is:inline>
      const storedTheme = window.localStorage.getItem('theme');
      document.documentElement.dataset.theme = storedTheme === 'light' ? 'light' : 'dark';
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..800;1,9..144,400..800&family=Outfit:wght@300..700&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href={`/${lang}`} aria-label="Piotr Ponikiewski">
          <span>PP</span>
        </a>
        <nav class="nav-links" aria-label="Main navigation">
          <a href="#projects">{page.nav.projects}</a>
          <a href="#process">{page.nav.process}</a>
          <a href="#stack">{page.nav.stack}</a>
          <a href="#about">{page.nav.about}</a>
          <a href="#contact">{page.nav.contact}</a>
        </nav>
        <div class="top-actions">
          <a class="text-link" href={page.nav.languageHref}>{page.nav.language}</a>
          <a class="icon-link" href={cvPath} download aria-label={page.nav.cv}>
            <Download size={17} />
          </a>
          <ThemeToggle client:load />
        </div>
      </header>

      <main>
        <section class="hero section">
          <div class="hero-copy">
            <div class="status-pill"><span></span>{page.hero.status}</div>
            <p class="eyebrow">{page.hero.eyebrow}</p>
            <h1>{page.hero.title}</h1>
            <p class="lead">{page.hero.lead}</p>
            <div class="cta-row">
              <a class="button primary" href="#projects">{page.hero.primaryCta}</a>
              <a class="button secondary" href={`mailto:${page.contact.email}`}>{page.hero.secondaryCta}</a>
            </div>
          </div>

          <aside class="cockpit" aria-label={page.hero.panelTitle}>
            <div class="cockpit-header">
              <span>{page.hero.panelTitle}</span>
              <span class="live-dot"></span>
            </div>
            <div class="metric-grid">
              {page.hero.panelItems.map(([label, value]) => (
                <div class="metric">
                  <span>{label}</span>
                  <strong>{value}</strong>
                </div>
              ))}
            </div>
            <div class="activity-log">
              {page.hero.activity.map((item) => (
                <div><span></span>{item}</div>
              ))}
            </div>
          </aside>
        </section>

        <section id="projects" class="section">
          <div class="section-heading">
            <p class="eyebrow">{page.projectsIntro.kicker}</p>
            <h2>{page.projectsIntro.title}</h2>
            <p>{page.projectsIntro.text}</p>
          </div>

          <div class="project-grid">
            {page.projects.map((project, index) => (
              <article class:list={['project-card', index === 0 && 'featured']}>
                <div class="project-visual">
                  <strong>{project.name}</strong>
                </div>
                <div class="project-content">
                  <div class="project-meta">
                    <span>{project.status}</span>
                    <span>{project.kind}</span>
                  </div>
                  <h3>{project.name}</h3>
                  <p>{project.description}</p>
                  <ul>
                    {project.highlights.map((highlight) => <li>{highlight}</li>)}
                  </ul>
                  <div class="tag-row">
                    {project.stack.map((item) => <span>{item}</span>)}
                  </div>
                  {project.links.length > 0 && (
                    <div class="link-row">
                      {project.links.map((link) => (
                        <a href={link.href} target="_blank" rel="noreferrer">
                          {link.label}
                          <ArrowUpRight size={15} />
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="process" class="section split-section">
          <div class="section-heading compact">
            <p class="eyebrow">{page.process.kicker}</p>
            <h2>{page.process.title}</h2>
          </div>
          <div class="process-grid">
            {page.process.items.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="stack" class="section">
          <div class="section-heading">
            <p class="eyebrow">{page.stack.kicker}</p>
            <h2>{page.stack.title}</h2>
          </div>
          <div class="stack-grid">
            {page.stack.groups.map(([title, items]) => (
              <article>
                <h3>{title}</h3>
                <div class="tag-row">
                  {items.map((item) => <span>{item}</span>)}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="about" class="section about-section">
          <div class="portrait-wrap">
            <img src={profilePath} alt="Piotr Ponikiewski" loading="lazy" />
          </div>
          <div>
            <p class="eyebrow">{page.about.kicker}</p>
            <h2>{page.about.title}</h2>
            <p>{page.about.text}</p>
          </div>
        </section>

        <section id="contact" class="section contact-section">
          <p class="eyebrow">{page.contact.kicker}</p>
          <h2>{page.contact.title}</h2>
          <p>{page.contact.text}</p>
          <div class="contact-actions">
            <a class="button primary" href={`mailto:${page.contact.email}`}>
              <Mail size={17} />
              {page.contact.email}
            </a>
            <a class="button secondary" href="https://www.linkedin.com/in/piotr-ponikiewski-580679232/" target="_blank" rel="noreferrer">
              <ArrowUpRight size={17} />
              {page.contact.linkedin}
            </a>
            <a class="button secondary" href="https://github.com/pponikiewski" target="_blank" rel="noreferrer">
              <ArrowUpRight size={17} />
              {page.contact.github}
            </a>
            <a class="button secondary" href={cvPath} download>
              <Download size={17} />
              {page.contact.cv}
            </a>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
