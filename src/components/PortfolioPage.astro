---
import { ThemeToggle } from './ThemeToggle'
import ProjectRow from './ProjectRow.astro'
import type { Lang, PageContent } from '@/i18n/content'

interface Props {
  lang: Lang
  page: PageContent
}

const { lang, page } = Astro.props
const cvPath = `/cv/Piotr_Ponikiewski_cv_${lang}.pdf`
const profilePath = '/images/1.jpg'

const [firstName, ...restName] = page.hero.name.split(' ')
const lastName = restName.join(' ')

---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={page.meta.description} />
    <title>{page.meta.title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      const stored = window.localStorage.getItem('theme');
      const system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = stored === 'light' || stored === 'dark' ? stored : system;
      document.documentElement.classList.add('js');
</script>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-in">
        <a class="brand" href={`/${lang}`} aria-label={page.hero.name}>
          <span class="dot"></span>
          {page.hero.name}
        </a>
        <nav class="nav" aria-label="Main navigation">
          <a href="#projects">{page.nav.projects}</a>
          <a href="#stack">{page.nav.stack}</a>
          <a href="#about">{page.nav.about}</a>
          <a href="#contact">{page.nav.contact}</a>
        </nav>
        <div class="top-actions">
          <a class="lang" href={page.nav.languageHref}>{page.nav.language}</a>
          <ThemeToggle client:load />
        </div>
      </div>
    </header>

    <div class="page">
      <div class="vmid"></div>
      <div class="inner">

        <!-- HERO -->
        <section class="hero" style="border-bottom: 0;">
          <div class="hero-bg" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" width="100%" height="100%">
              <defs>
                <radialGradient id="hbg-glow" cx="52%" cy="61%" r="38%">
                  <stop offset="0%"   stop-color="#ff4d2e" stop-opacity="0.16" />
                  <stop offset="100%" stop-color="#ff4d2e" stop-opacity="0" />
                </radialGradient>
                <radialGradient id="hbg-sun" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"   stop-color="#ffb87a" stop-opacity="0.5" />
                  <stop offset="100%" stop-color="#ff4d2e" stop-opacity="0" />
                </radialGradient>
                <linearGradient id="hbg-fade" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%"   stop-color="black" />
                  <stop offset="35%"  stop-color="black" />
                  <stop offset="62%"  stop-color="white" />
                  <stop offset="100%" stop-color="white" />
                </linearGradient>
                <mask id="hbg-mask">
                  <rect width="1920" height="1080" fill="url(#hbg-fade)" />
                </mask>
              </defs>
              <rect width="1920" height="1080" fill="url(#hbg-glow)" />
              <ellipse cx="998" cy="659" rx="85" ry="58" fill="url(#hbg-sun)" />
              <line x1="0" y1="660" x2="1920" y2="660" stroke="#ff4d2e" stroke-opacity="0.10" stroke-width="1" />
              <g mask="url(#hbg-mask)">
                <path class="hbg-far"  d="M0,1080 L0,620 L90,578 L190,612 L290,528 L390,568 L490,492 L585,534 L670,502 L755,548 L855,466 L950,512 L1005,482 L1075,522 L1160,488 L1265,542 L1365,502 L1460,562 L1560,526 L1660,572 L1755,538 L1845,582 L1920,556 L1920,1080 Z" />
                <path class="hbg-mid"  d="M0,1080 L0,712 L110,664 L225,696 L345,644 L465,684 L585,622 L705,666 L825,636 L945,670 L1065,640 L1185,676 L1305,650 L1425,686 L1545,660 L1665,696 L1920,670 L1920,1080 Z" />
                <path class="hbg-near" d="M0,1080 L0,808 L135,762 L270,794 L410,752 L550,784 L690,746 L830,774 L970,750 L1110,778 L1250,758 L1390,784 L1530,764 L1670,790 L1920,774 L1920,1080 Z" />
              </g>
            </svg>
          </div>
          <div class="hero-telem mono" aria-hidden="true">
            <div class="telem-hdr">{page.telemetry.heading}<span class="telem-dots"><span>.</span><span>.</span><span>.</span></span></div>
            {page.telemetry.rows.map((row) => (
              <div class="telem-row">
                <span class="tk">{row.k}</span>
                {'kind' in row && row.kind === 'clock' ? (
                  <span class="tv" id="tele-clock">{row.v}</span>
                ) : 'kind' in row && row.kind === 'green' ? (
                  <span class="tv g">{row.v}</span>
                ) : 'kind' in row && row.kind === 'accent' ? (
                  <span class="tv a">{row.v}</span>
                ) : (
                  <span class="tv">{row.v}</span>
                )}
              </div>
            ))}
          </div>
          <div class="hero-content">
            <h1>{firstName}<br /><span class="light">{lastName}</span></h1>
            <p class="hero-sub">{page.hero.lead}</p>
            <div class="hero-type mono">
              <span class="lbl">~ currently: </span><span id="typed-text"></span><span class="cursor"></span>
            </div>
            <div class="hero-cta">
              <a class="btn primary" href="#projects">{page.hero.primaryCta}</a>
              <a class="btn ghost" href={`mailto:${page.contact.email}`}>{page.hero.secondaryCta}</a>
            </div>
          </div>
        </section>

        <script define:vars={{ phrases: page.hero.typingPhrases }}>
          (function () {
            let pi = 0, ci = 0, del = false;
            const el = document.getElementById('typed-text');
            if (!el) return;
            function type() {
              const c = phrases[pi];
              if (!del) {
                el.textContent = c.slice(0, ci + 1);
                ci++;
                if (ci === c.length) { del = true; setTimeout(type, 2200); return; }
              } else {
                el.textContent = c.slice(0, ci - 1);
                ci--;
                if (ci === 0) { del = false; pi = (pi + 1) % phrases.length; }
              }
              setTimeout(type, del ? 18 : 42);
            }
            type();
          })();
        </script>

        <script>
          import '../scripts/clock'
          import '../scripts/scroll-reveal'
        </script>

        <script is:inline>
          (function () {
            const dots = document.querySelectorAll('.telem-dots span');
            if (!dots.length) return;
            let n = 0;
            setInterval(function () {
              n = (n + 1) % (dots.length + 1);
              dots.forEach(function (d, i) {
                d.style.opacity = i < n ? '1' : '0';
              });
            }, 500);
          })();
        </script>

        <!-- PROJECTS -->
        <section id="projects">
          <div class="sec-head"><span class="num">01</span><h2>{page.projectsIntro.kicker}</h2></div>
          {page.projects.map((project, index) => (
            <ProjectRow project={project} index={index} />
          ))}

          {page.moreProjects.length > 0 && (
            <>
              <div id="more-projects-list">
                {page.moreProjects.map((project, index) => (
                  <ProjectRow project={project} index={page.projects.length + index} client:load />
                ))}
              </div>

              <div class="proj-more-wrap">
                <button id="more-projects-btn" class="btn ghost proj-more-btn" aria-expanded="false">
                  {lang === 'pl' ? 'Więcej projektów' : 'More projects'}
                </button>
              </div>

              <script is:inline define:vars={{ labelMore: lang === 'pl' ? 'Więcej projektów' : 'More projects', labelLess: lang === 'pl' ? 'Pokaż mniej' : 'Show less' }}>
                (function () {
                  const list = document.getElementById('more-projects-list');
                  const btn = document.getElementById('more-projects-btn');
                  if (!list || !btn) return;
                  list.style.display = 'none';
                  btn.addEventListener('click', function () {
                    const open = list.style.display !== 'none';
                    list.style.display = open ? 'none' : 'block';
                    btn.textContent = open ? labelMore : labelLess;
                    btn.setAttribute('aria-expanded', String(!open));
                  });
                })();
              </script>
            </>
          )}
        </section>

        <!-- STACK -->
        <section id="stack" class="stack-wrap">
          <div class="sec-head"><span class="num">02</span><h2>{page.stack.kicker}</h2></div>
          <div class="stack-grid">
            {page.stack.groups.map((group, i) => (
              <div class="stack-cell">
                <div class="l">
                  <span class="l-idx">{String(i + 1).padStart(2, '0')}</span>
                  <span class="l-title">{group.title}</span>
                </div>
                <div class="stack-tags">
                  {group.items.map((item) => <span>{item}</span>)}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- ABOUT -->
        <section id="about">
          <div class="sec-head"><span class="num">03</span><h2>{page.about.kicker}</h2></div>
          <div class="about-wrap">
            <figure class="about-figure">
              <div class="about-photo">
                <img src={profilePath} alt={page.hero.name} loading="lazy" />
              </div>
            </figure>
            <div class="about-body">
              <p class="about-lead">{page.about.lead}</p>
              <p class="about-text">{page.about.text}</p>
              {page.about.text2 && <p class="about-text about-text--2">{page.about.text2}</p>}
              <dl class="about-facts">
                {page.about.facts.map(([k, v]) => (
                  <div class="fact">
                    <dt>{k}</dt>
                    <dd>{v}</dd>
                  </div>
                ))}
              </dl>
              <p class="about-looking"><span class="ico">▸</span>{page.about.looking}</p>
              <div class="about-tags">
                {page.hero.interests.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
          </div>
        </section>

        <!-- CONTACT -->
        <section id="contact" class="contact-wrap">
          <div class="sec-head"><span class="num">04</span><h2>{page.contact.kicker}</h2></div>
          <h3 class="contact-big" set:html={page.contact.title}></h3>
          <p class="contact-text">{page.contact.text}</p>
          <a class="contact-row" href={`mailto:${page.contact.email}`}>
            <span class="ck">Email</span>
            <span class="cv">{page.contact.email}</span>
            <span class="ca">↗</span>
          </a>
          <a class="contact-row" href={page.contact.linkedinHref} target="_blank" rel="noreferrer">
            <span class="ck">{page.contact.linkedin}</span>
            <span class="cv">{page.contact.linkedinLabel}</span>
            <span class="ca">↗</span>
          </a>
          <a class="contact-row" href={page.contact.githubHref} target="_blank" rel="noreferrer">
            <span class="ck">{page.contact.github}</span>
            <span class="cv">{page.contact.githubLabel}</span>
            <span class="ca">↗</span>
          </a>
          <a class="contact-row" href={cvPath} download>
            <span class="ck">CV</span>
            <span class="cv">{page.contact.cv}</span>
            <span class="ca">↓</span>
          </a>
        </section>

        <footer class="site-footer">
          <span>© 2026 {page.hero.name}</span>
          <span>Built with Astro</span>
        </footer>

      </div>
    </div>

    <button id="scroll-arrow" aria-label="Scroll">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10 4v12M4 10l6 6 6-6"/>
      </svg>
    </button>

    <script is:inline>
      (function () {
        var btn = document.getElementById('scroll-arrow');
        if (!btn) return;
        var footer = document.querySelector('.site-footer');
        var sections = ['projects', 'stack', 'about', 'contact'];
        var atBottom = false;

        if (footer && 'IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            atBottom = entries[0].isIntersecting;
            btn.classList.toggle('is-bottom', atBottom);
          }, { threshold: 0.1 });
          io.observe(footer);
        }

        btn.addEventListener('click', function () {
          if (atBottom) {
            window.scrollTo({ top: 0, behavior: 'smooth' });
            return;
          }
          var mid = window.scrollY + window.innerHeight / 2;
          var next = null;
          for (var i = 0; i < sections.length; i++) {
            var el = document.getElementById(sections[i]);
            if (el && el.getBoundingClientRect().top + window.scrollY > mid + 10) {
              next = el;
              break;
            }
          }
          if (next) {
            next.scrollIntoView({ behavior: 'smooth' });
          } else {
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
          }
        });
      })();
    </script>
  </body>
</html>

<style>
  .telem-dots span {
    opacity: 0;
    transition: opacity 0.35s ease;
  }

</style>
